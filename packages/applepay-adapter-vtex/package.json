{
  "name": "@cielo/applepay-headless-vtex-adapter",
  "version": "0.1.0",
  "description": "VTEX + Cielo eWallet connector adapter for the Apple Pay headless orchestration core.",
  "private": false,
  "type": "module",
  "license": "MIT",
  "keywords": [
    "apple-pay",
    "cielo",
    "vtex",
    "payments",
    "headless-commerce"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/e2m-store/cielo-applepay-headless-vtex.git",
    "directory": "packages/applepay-adapter-vtex"
  },
  "homepage": "https://github.com/e2m-store/cielo-applepay-headless-vtex/tree/main/packages/applepay-adapter-vtex#readme",
  "bugs": {
    "url": "https://github.com/e2m-store/cielo-applepay-headless-vtex/issues"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean"
  },
  "dependencies": {
    "@cielo/applepay-headless-vtex": "^0.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
